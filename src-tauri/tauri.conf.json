{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/refs/heads/main/tooling/cli/schema.json",
  "productName": "Window Timer",
  "version": "0.1.0",
  "identifier": "com.windowtimer.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Window Timer",
        "width": 320,
        "height": 480,
        "resizable": true,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
